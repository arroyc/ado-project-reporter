{
  "name": "project-status-report-agent",
  "version": "1.0.2",
  "description": "AI-powered Project Status Report Agent — fetches Azure DevOps data, generates LLM-summarized reports",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "psr-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:static": "node dist/index.js --static",
    "lint": "eslint src/ test/",
    "audit:check": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "azure-devops",
    "project-status",
    "report-generator",
    "llm",
    "openai",
    "ollama",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arroyc/ado-project-reporter.git"
  },
  "homepage": "https://github.com/arroyc/ado-project-reporter#readme",
  "bugs": {
    "url": "https://github.com/arroyc/ado-project-reporter/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "azure-devops-node-api": "^14.1.0",
    "dotenv": "^16.4.7",
    "openai": "^4.86.2"
  },
  "devDependencies": {
    "@bradygaster/squad-cli": "^0.8.20",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
