# Project Status Report Agent — Ollama (local LLM) configuration
#
# Copy this file to .env.ollama and fill in your ADO credentials:
#   cp environment-examples/.env.ollama.example .env.ollama
#
# Then run with:  dotenv -e .env.ollama -- npx psr-agent

# ── Azure DevOps ────────────────────────────────────────────────────────
ADO_ORG_URL=https://dev.azure.com/yourorg
ADO_PAT=your-personal-access-token
ADO_PROJECT=YourProject

# ── ADO Query Filters ──────────────────────────────────────────────────
ADO_TEAM_MEMBERS=
ADO_REQUIRED_TAGS=
ADO_WORK_ITEM_TYPES=Bug,Prod Change Request,Feature,User Story,Task
ADO_STATES=Closed,Removed,Resolved

# ── Category Tag Mappings ───────────────────────────────────────────────
ADO_S360_TAGS=s360
ADO_ICM_TAGS=icm
ADO_ROLLOUT_TAGS=rollout
ADO_MONITORING_TAGS=Monitoring,dev-test-ci,pipeline-monitoring
ADO_SUPPORT_TAGS=support
ADO_RISK_TAGS=risk,blocker
ADO_MILESTONE_TAGS=milestone

# ── Reporting Period ────────────────────────────────────────────────────
REPORT_START_DATE=2026-02-01
REPORT_END_DATE=2026-03-01

# ── LLM (Ollama — local) ───────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=llava:13b
# LLM_API_KEY is not needed for Ollama — handled automatically
VISION_ENABLED=true

# ── Report Metadata ─────────────────────────────────────────────────────
TEAM_NAME=My Team
CLIENT_NAME=My Client
PREPARED_BY=Your Name

# ── Output ──────────────────────────────────────────────────────────────
OUTPUT_PATH=./output/report-ollama.md
TEMPLATE_PATH=./template_report.md
VERBOSE=true
ENABLE_COMPARISON=false

# ── Section Titles (customizable report headers) ────────────────────────
SECTION_KEY_METRICS=Key Metrics
SECTION_S360=S360 Status
SECTION_RELEASES=Releases
SECTION_ICM=ICM On-Call Activity
SECTION_MONITORING_SUPPORT=Monitoring & Support
SECTION_MONITORING=Monitoring
SECTION_SUPPORT=Support
SECTION_COMPARISON=Month-over-Month Comparison
SECTION_TREND_ANALYSIS=Trend Analysis

# ── Performance ──────────────────────────────────────────────────────────
CACHE_DIR=.cache
CACHE_TTL_MINUTES=60
CONCURRENCY=10
